# Каталог загрузок (обложки и т.д.). По умолчанию — каталог media рядом с manage.py.
# В Docker/проде задайте абсолютный путь с записью, например: DJANGO_MEDIA_ROOT=/smartlib-assets/

# Origin фронтендов для CORS (через запятую)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Хосты Django
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Сид суперпользователя — задайте в своём .env, в репозиторий не коммитьте
# SUPER_ADMIN_PASSWORD=
